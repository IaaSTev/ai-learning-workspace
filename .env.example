OPENAI_API_KEY=
# Optional: defaults to gpt-4o for syllabus extraction
# OPENAI_MODEL=gpt-4o-mini
# Embeddings for course-level RAG (rag.md)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: RAG data directory (default: OS temp). SQLite DB lives here as rag.sqlite unless overridden.
# RAG_DATA_DIR=C:\\path\\to\\rag-data
# Optional: full path to SQLite DB file (overrides join(RAG_DATA_DIR, "rag.sqlite"))
# RAG_SQLITE_PATH=C:\\path\\to\\rag.sqlite
